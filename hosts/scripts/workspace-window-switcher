#!/usr/bin/env python3

import json
import subprocess
import sys

CHOOSE_BINARY = "/etc/profiles/per-user/lucas.zanoni/bin/choose"


def find_aerospace_binary():
    result = subprocess.run(
        ["pgrep", "-x", "AeroSpace"], capture_output=True, text=True
    )
    if result.returncode != 0 or not result.stdout.strip():
        sys.exit(1)

    pid = result.stdout.strip().split("\n")[0]
    lsof_result = subprocess.run(
        ["lsof", "-p", pid], capture_output=True, text=True
    )
    for line in lsof_result.stdout.splitlines():
        if "MacOS/AeroSpace" in line:
            app_path = line.split()[-1]
            store_path = app_path.split("/Applications/")[0]
            return f"{store_path}/bin/aerospace"
    sys.exit(1)


AEROSPACE_BINARY = find_aerospace_binary()


def get_workspace_windows():
    result = subprocess.run(
        [AEROSPACE_BINARY, "list-windows", "--workspace", "focused", "--json"],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        return []
    return json.loads(result.stdout)


def get_focused_window_id():
    result = subprocess.run(
        [AEROSPACE_BINARY, "list-windows", "--focused", "--json"],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        return None
    windows = json.loads(result.stdout)
    return windows[0]["window-id"] if windows else None


def focus_window(window_id):
    subprocess.run([AEROSPACE_BINARY, "focus", "--window-id", str(window_id)])


def build_display_line(window):
    return f"{window['app-name']}: {window['window-title']}"


def show_picker_with_choose(windows, focused_window_id):
    non_focused_windows = [w for w in windows if w["window-id"] != focused_window_id]
    focused_windows = [w for w in windows if w["window-id"] == focused_window_id]
    ordered_windows = non_focused_windows + focused_windows

    display_lines = [build_display_line(w) for w in ordered_windows]
    picker_input = "\n".join(display_lines)

    result = subprocess.run(
        [CHOOSE_BINARY, "-n", str(min(len(ordered_windows), 10)), "-p", "Switch to:"],
        input=picker_input,
        capture_output=True,
        text=True,
    )

    if result.returncode != 0 or not result.stdout.strip():
        return

    selected_line = result.stdout.strip()
    for window in ordered_windows:
        if build_display_line(window) == selected_line:
            focus_window(window["window-id"])
            return


def main():
    windows = get_workspace_windows()
    if not windows:
        return

    focused_window_id = get_focused_window_id()
    show_picker_with_choose(windows, focused_window_id)


if __name__ == "__main__":
    main()
