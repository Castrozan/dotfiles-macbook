#!/usr/bin/env python3

import glob
import json
import os
import socket
import threading
import time
import warnings

warnings.filterwarnings("ignore", message="PyObjCPointer created")

import AppKit
from Foundation import NSMakeRect, NSMakePoint
from PyObjCTools import AppHelper

SOCKET_PATH = "/tmp/workspace-switcher.sock"
ACTIVE_FLAG_PATH = "/tmp/workspace-switcher.active"
PERFORMANCE_LOG_PATH = "/tmp/workspace-switcher-perf.log"
CARD_WIDTH = 140
CARD_HEIGHT = 120
CARD_ICON_SIZE = 64
CARD_SPACING = 12
OVERLAY_PADDING = 16
OVERLAY_CORNER_RADIUS = 14
CARD_CORNER_RADIUS = 10
TITLE_FONT_SIZE = 11
SELECTION_BORDER_WIDTH = 3
COMMIT_TIMEOUT_SECONDS = 10.0


class ActivationPerformanceProfiler:
    PHASE_ORDER = (
        "begin",
        "worker_started",
        "ipc_workspace_done",
        "ipc_focus_done",
        "main_callback",
        "mru_sort_done",
        "overlay_build_done",
        "overlay_visible",
    )

    def __init__(self, log_path):
        self._log_path = log_path
        self._lock = threading.Lock()
        self._reset_locked()

    def _reset_locked(self):
        self._timestamps_ns_by_phase = {}
        self._workspace_window_count = 0

    def begin_new_activation(self):
        with self._lock:
            self._reset_locked()
            self._timestamps_ns_by_phase["begin"] = time.perf_counter_ns()

    def mark_phase(self, phase_name):
        with self._lock:
            if "begin" not in self._timestamps_ns_by_phase:
                return
            self._timestamps_ns_by_phase[phase_name] = time.perf_counter_ns()

    def record_workspace_window_count(self, count):
        with self._lock:
            self._workspace_window_count = count

    def emit_activation_report(self):
        with self._lock:
            timestamps = dict(self._timestamps_ns_by_phase)
            window_count = self._workspace_window_count
            self._reset_locked()
        if "begin" not in timestamps:
            return
        baseline_ns = timestamps.pop("begin")
        line_parts = [f"windows={window_count}"]
        for phase_name in self.PHASE_ORDER[1:]:
            if phase_name in timestamps:
                delta_ms = (timestamps[phase_name] - baseline_ns) / 1e6
                line_parts.append(f"{phase_name}={delta_ms:.3f}")
        try:
            with open(self._log_path, "a") as log_file:
                log_file.write(" ".join(line_parts) + "\n")
        except OSError:
            pass


performance_profiler = ActivationPerformanceProfiler(PERFORMANCE_LOG_PATH)


class AeroSpaceWindowProvider:
    def __init__(self):
        self._cached_socket_path = None
        self._json_decoder = json.JSONDecoder()

    def _resolve_aerospace_socket_path(self):
        username = os.environ.get("USER", os.getlogin())
        expected_path = f"/tmp/bobko.aerospace-{username}.sock"
        if os.path.exists(expected_path):
            return expected_path
        matching_sockets = glob.glob("/tmp/bobko.aerospace-*.sock")
        return matching_sockets[0] if matching_sockets else None

    def _get_socket_path(self):
        if self._cached_socket_path is None:
            self._cached_socket_path = self._resolve_aerospace_socket_path()
        return self._cached_socket_path

    def _send_ipc_command(self, args):
        socket_path = self._get_socket_path()
        if socket_path is None:
            return None
        try:
            ipc_socket = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
            ipc_socket.settimeout(2)
            ipc_socket.connect(socket_path)
            request_payload = json.dumps(
                {"args": args, "stdin": "", "windowId": None, "workspace": None}
            ).encode()
            ipc_socket.sendall(request_payload)
            ipc_socket.shutdown(socket.SHUT_WR)
            response_data = b""
            while True:
                chunk = ipc_socket.recv(4096)
                if not chunk:
                    break
                response_data += chunk
            ipc_socket.close()
            response, _ = self._json_decoder.raw_decode(response_data.decode())
            if response.get("exitCode", 1) != 0:
                return None
            return response.get("stdout", "")
        except (OSError, json.JSONDecodeError, UnicodeDecodeError):
            self._cached_socket_path = None
            return None

    def get_focused_workspace_windows(self):
        stdout = self._send_ipc_command(
            ["list-windows", "--workspace", "focused", "--json"]
        )
        if stdout is None:
            return []
        try:
            return json.loads(stdout)
        except json.JSONDecodeError:
            return []

    def get_focused_window_id(self):
        stdout = self._send_ipc_command(["list-windows", "--focused", "--json"])
        if stdout is None:
            return None
        try:
            windows = json.loads(stdout)
            return windows[0]["window-id"] if windows else None
        except (json.JSONDecodeError, IndexError, KeyError):
            return None

    def focus_window(self, window_id):
        self._send_ipc_command(["focus", "--window-id", str(window_id)])


class AppIconProvider:
    def __init__(self):
        self._icon_cache = {}

    def prewarm_cache_from_running_applications(self):
        workspace = AppKit.NSWorkspace.sharedWorkspace()
        for running_application in workspace.runningApplications():
            app_name = running_application.localizedName()
            if not app_name or app_name in self._icon_cache:
                continue
            icon = running_application.icon()
            if icon:
                self._icon_cache[app_name] = icon

    def get_icon_for_app_name(self, app_name):
        if app_name in self._icon_cache:
            return self._icon_cache[app_name]
        icon = self._resolve_icon_from_running_applications(app_name)
        self._icon_cache[app_name] = icon
        return icon

    def _resolve_icon_from_running_applications(self, app_name):
        workspace = AppKit.NSWorkspace.sharedWorkspace()
        for running_application in workspace.runningApplications():
            if running_application.localizedName() == app_name:
                icon = running_application.icon()
                if icon:
                    return icon
        return workspace.iconForFileType_("app")


class NonActivatingPanel(AppKit.NSPanel):
    def canBecomeKeyWindow(self):
        return False

    def canBecomeMainWindow(self):
        return False


class SwitcherOverlayPanel:
    def __init__(self, icon_provider):
        self._panel = None
        self._background_view = None
        self._card_views_with_borders = []
        self._icon_provider = icon_provider

    def _create_floating_panel(self):
        initial_frame = NSMakeRect(0, 0, 400, 200)
        style_mask = AppKit.NSWindowStyleMaskBorderless | (1 << 7)
        self._panel = (
            NonActivatingPanel.alloc().initWithContentRect_styleMask_backing_defer_(
                initial_frame,
                style_mask,
                AppKit.NSBackingStoreBuffered,
                False,
            )
        )
        self._panel.setReleasedWhenClosed_(False)
        self._panel.setLevel_(AppKit.NSPopUpMenuWindowLevel)
        self._panel.setOpaque_(False)
        self._panel.setBackgroundColor_(AppKit.NSColor.clearColor())
        self._panel.setHasShadow_(True)
        self._panel.setIgnoresMouseEvents_(True)
        self._panel.setHidesOnDeactivate_(False)
        self._panel.setAlphaValue_(1.0)
        self._panel.setCollectionBehavior_(
            AppKit.NSWindowCollectionBehaviorCanJoinAllSpaces
            | AppKit.NSWindowCollectionBehaviorStationary
        )

    def show_with_windows_and_selection(self, windows, selected_index):
        self._create_floating_panel()
        self._build_overlay_with_cards(windows, selected_index)
        self._center_on_main_screen()
        performance_profiler.mark_phase("overlay_build_done")
        self._panel.orderFrontRegardless()

    def update_selected_index(self, selected_index):
        for card_index, (card_view, border_view) in enumerate(
            self._card_views_with_borders
        ):
            is_selected = card_index == selected_index
            self._apply_card_selection_style(card_view, border_view, is_selected)

    def hide(self):
        if self._panel is not None:
            self._panel.orderOut_(None)
            self._panel.close()
            self._panel = None
        self._background_view = None
        self._card_views_with_borders = []

    def _build_overlay_with_cards(self, windows, selected_index):
        card_count = len(windows)
        total_width = (
            OVERLAY_PADDING * 2
            + card_count * CARD_WIDTH
            + max(0, card_count - 1) * CARD_SPACING
        )
        total_height = OVERLAY_PADDING * 2 + CARD_HEIGHT

        panel_frame = NSMakeRect(0, 0, total_width, total_height)
        self._panel.setFrame_display_(panel_frame, False)

        self._background_view = AppKit.NSVisualEffectView.alloc().initWithFrame_(
            NSMakeRect(0, 0, total_width, total_height)
        )
        self._background_view.setMaterial_(13)
        self._background_view.setBlendingMode_(0)
        self._background_view.setState_(1)
        self._background_view.setWantsLayer_(True)
        self._background_view.layer().setCornerRadius_(OVERLAY_CORNER_RADIUS)
        self._background_view.layer().setMasksToBounds_(True)
        self._background_view.layer().setBackgroundColor_(
            AppKit.NSColor.blackColor().colorWithAlphaComponent_(0.7).CGColor()
        )
        self._panel.contentView().addSubview_(self._background_view)

        for window_index, window_data in enumerate(windows):
            horizontal_offset = OVERLAY_PADDING + window_index * (
                CARD_WIDTH + CARD_SPACING
            )
            vertical_offset = OVERLAY_PADDING
            is_selected = window_index == selected_index

            card_view, border_view = self._create_window_card(
                window_data, horizontal_offset, vertical_offset, is_selected
            )
            self._background_view.addSubview_(card_view)
            self._card_views_with_borders.append((card_view, border_view))

    def _create_window_card(
        self, window_data, horizontal_offset, vertical_offset, is_selected
    ):
        card_frame = NSMakeRect(
            horizontal_offset, vertical_offset, CARD_WIDTH, CARD_HEIGHT
        )
        card_view = AppKit.NSView.alloc().initWithFrame_(card_frame)
        card_view.setWantsLayer_(True)
        card_view.layer().setCornerRadius_(CARD_CORNER_RADIUS)

        border_view = AppKit.NSView.alloc().initWithFrame_(
            NSMakeRect(0, 0, CARD_WIDTH, CARD_HEIGHT)
        )
        border_view.setWantsLayer_(True)
        border_view.layer().setCornerRadius_(CARD_CORNER_RADIUS)
        border_view.layer().setBorderWidth_(SELECTION_BORDER_WIDTH)
        card_view.addSubview_(border_view)

        app_name = window_data.get("app-name", "")
        app_icon = self._icon_provider.get_icon_for_app_name(app_name)
        icon_horizontal_offset = (CARD_WIDTH - CARD_ICON_SIZE) / 2
        icon_vertical_offset = CARD_HEIGHT - CARD_ICON_SIZE - 16
        icon_image_view = AppKit.NSImageView.alloc().initWithFrame_(
            NSMakeRect(
                icon_horizontal_offset,
                icon_vertical_offset,
                CARD_ICON_SIZE,
                CARD_ICON_SIZE,
            )
        )
        icon_image_view.setImage_(app_icon)
        icon_image_view.setImageScaling_(AppKit.NSImageScaleProportionallyUpOrDown)
        card_view.addSubview_(icon_image_view)

        window_title = window_data.get("window-title", app_name)
        title_frame = NSMakeRect(6, 4, CARD_WIDTH - 12, 28)
        title_text_field = AppKit.NSTextField.alloc().initWithFrame_(title_frame)
        title_text_field.setStringValue_(window_title)
        title_text_field.setBezeled_(False)
        title_text_field.setDrawsBackground_(False)
        title_text_field.setEditable_(False)
        title_text_field.setSelectable_(False)
        title_text_field.setAlignment_(AppKit.NSTextAlignmentCenter)
        title_text_field.setLineBreakMode_(4)
        title_text_field.setMaximumNumberOfLines_(2)
        card_view.addSubview_(title_text_field)

        self._apply_card_selection_style(card_view, border_view, is_selected)
        return card_view, border_view

    def _apply_card_selection_style(self, card_view, border_view, is_selected):
        if is_selected:
            card_view.layer().setBackgroundColor_(
                AppKit.NSColor.controlAccentColor()
                .colorWithAlphaComponent_(0.2)
                .CGColor()
            )
            border_view.layer().setBorderColor_(
                AppKit.NSColor.controlAccentColor()
                .colorWithAlphaComponent_(0.8)
                .CGColor()
            )
        else:
            card_view.layer().setBackgroundColor_(
                AppKit.NSColor.whiteColor().colorWithAlphaComponent_(0.05).CGColor()
            )
            border_view.layer().setBorderColor_(AppKit.NSColor.clearColor().CGColor())

        text_alpha = 1.0 if is_selected else 0.6
        font_weight = (
            AppKit.NSFontWeightMedium if is_selected else AppKit.NSFontWeightRegular
        )
        for subview in card_view.subviews():
            if isinstance(subview, AppKit.NSTextField):
                subview.setTextColor_(
                    AppKit.NSColor.whiteColor().colorWithAlphaComponent_(text_alpha)
                )
                subview.setFont_(
                    AppKit.NSFont.systemFontOfSize_weight_(TITLE_FONT_SIZE, font_weight)
                )

    def _center_on_main_screen(self):
        screen = AppKit.NSScreen.mainScreen()
        if screen is None:
            return
        screen_frame = screen.frame()
        panel_frame = self._panel.frame()
        centered_x = (screen_frame.size.width - panel_frame.size.width) / 2
        centered_y = (screen_frame.size.height - panel_frame.size.height) / 2
        self._panel.setFrameOrigin_(NSMakePoint(centered_x, centered_y))


class MostRecentlyUsedWindowTracker:
    def __init__(self):
        self._window_ids_by_recency = []

    def record_focused_window(self, window_id):
        if window_id in self._window_ids_by_recency:
            self._window_ids_by_recency.remove(window_id)
        self._window_ids_by_recency.insert(0, window_id)

    def sort_windows_by_recency(self, windows):
        window_id_to_position = {
            window_id: position
            for position, window_id in enumerate(self._window_ids_by_recency)
        }
        unknown_position = len(self._window_ids_by_recency)
        return sorted(
            windows,
            key=lambda window: window_id_to_position.get(
                window["window-id"], unknown_position
            ),
        )

    def remove_stale_window_ids(self, current_window_ids):
        self._window_ids_by_recency = [
            window_id
            for window_id in self._window_ids_by_recency
            if window_id in current_window_ids
        ]


class WindowSwitcherStateMachine:
    def __init__(self, aerospace_provider, overlay_panel, mru_tracker):
        self._aerospace = aerospace_provider
        self._overlay = overlay_panel
        self._mru_tracker = mru_tracker
        self._windows = []
        self._selected_index = 0
        self._active = False
        self._fetching_windows = False
        self._commit_requested_before_ready = False
        self._pending_direction_changes = 0
        self._commit_timeout_timer = None

    @property
    def is_active(self):
        return self._active

    def handle_next_command(self):
        if not self._active:
            self._begin_activation_with_direction(1)
            return
        if self._fetching_windows:
            self._pending_direction_changes += 1
            return
        self._advance_selection_by(1)
        self._restart_commit_timeout()

    def handle_prev_command(self):
        if not self._active:
            self._begin_activation_with_direction(-1)
            return
        if self._fetching_windows:
            self._pending_direction_changes -= 1
            return
        self._advance_selection_by(-1)
        self._restart_commit_timeout()

    def handle_commit_command(self):
        if not self._active:
            return
        if self._fetching_windows:
            self._commit_requested_before_ready = True
            return
        self._cancel_commit_timeout()
        self._focus_selected_window_and_deactivate()

    def handle_cancel_command(self):
        if not self._active:
            return
        self._cancel_commit_timeout()
        self._deactivate()

    def _create_active_flag_file(self):
        try:
            open(ACTIVE_FLAG_PATH, "w").close()
        except OSError:
            pass

    def _remove_active_flag_file(self):
        try:
            os.unlink(ACTIVE_FLAG_PATH)
        except FileNotFoundError:
            pass

    def _begin_activation_with_direction(self, initial_direction):
        performance_profiler.begin_new_activation()
        self._active = True
        self._create_active_flag_file()
        self._fetching_windows = True
        self._commit_requested_before_ready = False
        self._pending_direction_changes = initial_direction
        threading.Thread(target=self._fetch_windows_from_aerospace, daemon=True).start()

    def _fetch_windows_from_aerospace(self):
        performance_profiler.mark_phase("worker_started")
        windows = self._aerospace.get_focused_workspace_windows()
        performance_profiler.mark_phase("ipc_workspace_done")
        focused_window_id = self._aerospace.get_focused_window_id()
        performance_profiler.mark_phase("ipc_focus_done")
        AppHelper.callAfter(
            self._on_aerospace_windows_fetched, windows, focused_window_id
        )

    def _on_aerospace_windows_fetched(self, windows, focused_window_id):
        performance_profiler.mark_phase("main_callback")
        performance_profiler.record_workspace_window_count(len(windows))
        self._fetching_windows = False

        if not windows:
            self._deactivate()
            return

        current_window_ids = {w["window-id"] for w in windows}
        self._mru_tracker.remove_stale_window_ids(current_window_ids)
        self._mru_tracker.record_focused_window(focused_window_id)
        self._windows = self._mru_tracker.sort_windows_by_recency(windows)
        performance_profiler.mark_phase("mru_sort_done")

        total_direction = self._pending_direction_changes
        if total_direction > 0:
            self._selected_index = total_direction % len(self._windows)
        elif total_direction < 0:
            self._selected_index = (len(self._windows) + total_direction) % len(
                self._windows
            )
        else:
            self._selected_index = min(1, len(self._windows) - 1)

        if self._commit_requested_before_ready:
            self._focus_selected_window_and_deactivate()
            return

        self._overlay.show_with_windows_and_selection(
            self._windows, self._selected_index
        )
        performance_profiler.mark_phase("overlay_visible")
        performance_profiler.emit_activation_report()
        self._restart_commit_timeout()

    def _advance_selection_by(self, direction):
        if not self._windows:
            return
        self._selected_index = (self._selected_index + direction) % len(self._windows)
        self._overlay.update_selected_index(self._selected_index)

    def _focus_selected_window_and_deactivate(self):
        if self._windows and 0 <= self._selected_index < len(self._windows):
            selected_window = self._windows[self._selected_index]
            self._aerospace.focus_window(selected_window["window-id"])
        self._deactivate()

    def _deactivate(self):
        self._cancel_commit_timeout()
        self._remove_active_flag_file()
        self._active = False
        self._fetching_windows = False
        self._commit_requested_before_ready = False
        self._pending_direction_changes = 0
        self._windows = []
        self._selected_index = 0
        self._overlay.hide()

    def _restart_commit_timeout(self):
        self._cancel_commit_timeout()
        self._commit_timeout_timer = threading.Timer(
            COMMIT_TIMEOUT_SECONDS,
            lambda: AppHelper.callAfter(self.handle_commit_command),
        )
        self._commit_timeout_timer.start()

    def _cancel_commit_timeout(self):
        if self._commit_timeout_timer:
            self._commit_timeout_timer.cancel()
            self._commit_timeout_timer = None


class CommandSocketServer:
    def __init__(self, switcher_state, mru_tracker):
        self._switcher_state = switcher_state
        self._mru_tracker = mru_tracker

    def start_accepting_connections(self):
        server_thread = threading.Thread(target=self._run_server_loop, daemon=True)
        server_thread.start()

    def _run_server_loop(self):
        if os.path.exists(SOCKET_PATH):
            os.unlink(SOCKET_PATH)

        server_socket = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        server_socket.bind(SOCKET_PATH)
        os.chmod(SOCKET_PATH, 0o666)
        server_socket.listen(32)

        while True:
            try:
                client_connection, _ = server_socket.accept()
                client_connection.settimeout(0.5)
                try:
                    raw_command = client_connection.recv(1024).decode().strip()
                finally:
                    client_connection.close()
                if raw_command:
                    self._dispatch_command_to_main_thread(raw_command)
            except (OSError, UnicodeDecodeError):
                pass

    def _dispatch_command_to_main_thread(self, command):
        if command.startswith("focus:"):
            window_id_string = command[6:]
            try:
                window_id = int(window_id_string)
                self._mru_tracker.record_focused_window(window_id)
            except ValueError:
                pass
            return

        command_to_handler = {
            "next": self._switcher_state.handle_next_command,
            "prev": self._switcher_state.handle_prev_command,
            "commit": self._switcher_state.handle_commit_command,
            "cancel": self._switcher_state.handle_cancel_command,
        }
        handler = command_to_handler.get(command)
        if handler:
            AppHelper.callAfter(handler)


def remove_stale_active_flag_on_startup():
    try:
        os.unlink(ACTIVE_FLAG_PATH)
    except FileNotFoundError:
        pass


def main():
    remove_stale_active_flag_on_startup()

    application = AppKit.NSApplication.sharedApplication()
    application.setActivationPolicy_(AppKit.NSApplicationActivationPolicyAccessory)

    aerospace_provider = AeroSpaceWindowProvider()
    icon_provider = AppIconProvider()
    icon_provider.prewarm_cache_from_running_applications()
    overlay_panel = SwitcherOverlayPanel(icon_provider)
    mru_tracker = MostRecentlyUsedWindowTracker()
    switcher_state = WindowSwitcherStateMachine(
        aerospace_provider, overlay_panel, mru_tracker
    )

    command_server = CommandSocketServer(switcher_state, mru_tracker)
    command_server.start_accepting_connections()

    AppHelper.runEventLoop()


if __name__ == "__main__":
    main()
